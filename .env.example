# Environment contract — tacctile/fantasy
# Copy to .env.local (gitignored) and fill in real values. Never commit real secrets.

# --- Supabase (app runtime; also set in Vercel for Production + Preview) ---
# Modern API key pair (sb_publishable_... / sb_secret_...), not legacy anon/service_role JWTs.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Server-only. Bypasses RLS — never expose to the client, never prefix with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# --- Supabase CLI only (local `npx supabase db push`; never set in Vercel) ---
SUPABASE_DB_PASSWORD=your-database-password

# --- ESPN cookie auth (Wave 2; only needed for private ESPN leagues) ---
# Copy both values from the browser DevTools Network tab's raw outgoing Cookie
# header (not the Storage panel). Store exactly as extracted:
# ESPN_SWID keeps its literal curly braces; ESPN_S2 keeps exactly one layer of
# URL-encoding — never decode or re-encode either value.
ESPN_S2=your-espn-s2-cookie-value
ESPN_SWID={00000000-0000-0000-0000-000000000000}
